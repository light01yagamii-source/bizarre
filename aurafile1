-- generic toggle (+ optional slider) factory
local function makeToggle(group, opts)
	local lastNotif = 0
	local toggle = group:CreateToggle({
		Name = opts.Name,
		CurrentValue = false,
		Style = 2,
		Callback = function(val)
			local now = os.clock()
			if now - lastNotif < 0.2 then
				return
			end
			lastNotif = now
			if not opts.NoNotify then
				Starlight:Notification({
					Title = opts.Name,
					Icon = opts.Icon,
					Content = val and (opts.EnableText or opts.Name .. " Enabled!")
						or (opts.DisableText or opts.Name .. " Disabled!"),
					Duration = 3,
				}, (opts.IdPrefix or "") .. tostring(now))
			end
			if opts.Callback then
				pcall(opts.Callback, val)
			end
		end,
	}, opts.ToggleId)

	toggle:AddBind({
		CurrentValue = opts.Bind or "",
		SyncToggleState = false,
		Callback = function()
			toggle:Set({ CurrentValue = not toggle.Values.CurrentValue })
		end,
	}, "Bind")

	local slider
	if opts.SliderRange and opts.SliderDefault then
		slider = group:CreateSlider({
			Name = "",
			Range = opts.SliderRange,
			Increment = 1,
			CurrentValue = opts.SliderDefault,
			Callback = function(v)
				if opts.SliderCallback then
					pcall(opts.SliderCallback, v)
				end
			end,
		}, opts.SliderId)
	end

	return toggle, slider
end

