-- player_esp.lua (host this raw somewhere)
local paths = getgenv().RequiemPaths
local toggle = getgenv().PlayerESPToggle

local function update()
    for _,chr in pairs(workspace.Live:GetChildren()) do
        if not chr:FindFirstChild("ESPBox") then
            local b = Instance.new("BoxHandleAdornment")
            b.Name="ESPBox"; b.Adornee=chr; b.Size=chr:GetExtentsSize()
            b.Transparency=0.5; b.Color3=Color3.new(0,1,0); b.ZIndex=10
            b.Parent=chr
        end
    end
end

toggle:Callback(function(on)
    if on then
        toggle._conn = game:GetService("RunService").RenderStepped:Connect(update)
    else
        if toggle._conn then toggle._conn:Disconnect() end
        for _,chr in pairs(workspace.Live:GetChildren()) do
            local b=chr:FindFirstChild("ESPBox")
            if b then b:Destroy() end
        end
    end
end)
