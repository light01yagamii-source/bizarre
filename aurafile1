-- small helper so nothing breaks if a web request fails
local function safeLoad(url)
	local ok, res = pcall(game.HttpGet, game, url, true)
	if not ok or not res then
		warn("safeLoad: failed to download from " .. tostring(url))
		return nil
	end
	local func, err = loadstring(res)
	if not func then
		warn("safeLoad: invalid chunk from " .. tostring(url) .. ": " .. tostring(err))
		return nil
	end
	local success, ret = pcall(func)
	if not success then
		warn("safeLoad: error executing chunk from " .. tostring(url) .. ": " .. tostring(ret))
		return nil
	end
	return ret
end

